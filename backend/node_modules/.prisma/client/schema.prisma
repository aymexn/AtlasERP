generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum LicenseStatus {
  ACTIVE
  USED
  EXPIRED
}

enum MovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

enum SaleStatus {
  DRAFT
  VALIDATED
  CANCELLED
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

enum ManufacturingOrderStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Company {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  users               User[]
  licenseKeys         LicenseKey[]
  products            Product[]
  productFamilies     ProductFamily[]
  stockMovements      StockMovement[]
  sales               Sale[]
  expenses            Expense[]
  formulas            ProductFormula[]
  manufacturingOrders ManufacturingOrder[]
  auditLogs           AuditLog[]
  warehouses          Warehouse[]
  productStocks       ProductStock[]

  @@map("companies")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(EMPLOYEE)
  companyId    String   @map("company_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  auditLogs      AuditLog[]
  stockMovements StockMovement[]

  @@index([companyId])
  @@map("users")
}

model LicenseKey {
  id        String        @id @default(uuid()) @db.Uuid
  key       String        @unique
  status    LicenseStatus @default(ACTIVE)
  expiresAt DateTime      @map("expires_at")
  companyId String?       @map("company_id") @db.Uuid

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@map("license_keys")
}

enum ArticleType {
  SIMPLE
  SERVICE
  COMPOSED
  RAW_MATERIAL
  PACKAGING
  FINISHED_PRODUCT
  SEMI_FINISHED
}

model Product {
  id                String  @id @default(uuid()) @db.Uuid
  companyId         String  @map("company_id") @db.Uuid
  name              String
  sku               String // Main SKU / Item Code
  internalReference String? @map("internal_reference")
  barcode           String? @map("barcode")
  secondaryName     String? @map("secondary_name")
  description       String?

  articleType ArticleType @default(FINISHED_PRODUCT) @map("article_type")
  unit        String      @default("pcs")

  // Pricing
  taxRate         Decimal  @default(0.20) @map("tax_rate") @db.Decimal(5, 2)
  salePriceHt     Decimal  @map("sale_price_ht") @db.Decimal(10, 2)
  purchasePriceHt Decimal? @map("purchase_price_ht") @db.Decimal(10, 2)
  standardCost    Decimal  @map("standard_cost") @db.Decimal(10, 2)

  // Stock
  stockQuantity Decimal  @default(0) @map("stock_quantity") @db.Decimal(12, 3)
  minStock      Decimal  @default(0) @map("min_stock") @db.Decimal(12, 3)
  maxStock      Decimal? @map("max_stock") @db.Decimal(12, 3)
  stockValue    Decimal  @default(0) @map("stock_value") @db.Decimal(12, 2)

  isActive   Boolean @default(true) @map("is_active")
  isBlocked  Boolean @default(false) @map("is_blocked")
  trackStock Boolean @default(true) @map("track_stock")

  familyId String? @map("family_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  family                  ProductFamily?           @relation(fields: [familyId], references: [id], onDelete: SetNull)
  stockMovements          StockMovement[]
  saleItems               SaleItem[]
  formulas                ProductFormula[]
  formulaComponents       ProductFormulaLine[]
  stocks                  ProductStock[]
  manufacturingOrders     ManufacturingOrder[]
  manufacturingOrderLines ManufacturingOrderLine[]

  @@unique([companyId, sku])
  @@index([companyId])
  @@map("products")
}

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String
  code      String?
  location  String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stocks        ProductStock[]
  movementsFrom StockMovement[] @relation("WarehouseFrom")
  movementsTo   StockMovement[] @relation("WarehouseTo")

  @@unique([companyId, name])
  @@index([companyId])
  @@map("warehouses")
}

model ProductStock {
  id               String   @id @default(uuid()) @db.Uuid
  productId        String   @map("product_id") @db.Uuid
  warehouseId      String   @map("warehouse_id") @db.Uuid
  quantity         Decimal  @default(0) @db.Decimal(12, 3)
  reservedQuantity Decimal  @default(0) @map("reserved_quantity") @db.Decimal(12, 3)
  minThreshold     Decimal  @default(0) @map("min_threshold") @db.Decimal(12, 3)
  maxThreshold     Decimal? @map("max_threshold") @db.Decimal(12, 3)
  updatedAt        DateTime @updatedAt @map("updated_at")
  companyId        String   @map("company_id") @db.Uuid

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId, companyId])
  @@index([productId])
  @@index([companyId])
  @@map("product_stocks")
}

model ProductFamily {
  id          String  @id @default(uuid()) @db.Uuid
  companyId   String  @map("company_id") @db.Uuid
  name        String
  code        String?
  description String?
  colorBadge  String? @map("color_badge")
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")

  parentId String?         @map("parent_id") @db.Uuid
  parent   ProductFamily?  @relation("FamilyHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children ProductFamily[] @relation("FamilyHierarchy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]
  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("product_families")
}

enum FormulaStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model ProductFormula {
  id             String        @id @default(uuid()) @db.Uuid
  companyId      String        @map("company_id") @db.Uuid
  productId      String        @map("product_id") @db.Uuid
  name           String
  code           String?
  version        String        @default("1.0")
  description    String?
  outputQuantity Decimal       @default(1.0) @map("output_quantity") @db.Decimal(12, 3)
  outputUnit     String        @map("output_unit")
  scrapPercent   Decimal       @default(0) @map("scrap_percent") @db.Decimal(5, 2)
  status         FormulaStatus @default(DRAFT)
  isActive       Boolean       @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product            Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  company            Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines              ProductFormulaLine[]
  ManufacturingOrder ManufacturingOrder[]

  @@index([companyId])
  @@index([productId])
  @@map("product_formulas")
}

model ProductFormulaLine {
  id                 String  @id @default(uuid()) @db.Uuid
  formulaId          String  @map("formula_id") @db.Uuid
  componentProductId String  @map("component_product_id") @db.Uuid
  quantity           Decimal @db.Decimal(12, 3)
  unit               String
  wastagePercent     Decimal @default(0) @map("wastage_percent") @db.Decimal(5, 2)
  sortOrder          Int     @default(0) @map("sort_order")
  note               String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  formula   ProductFormula @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  component Product        @relation(fields: [componentProductId], references: [id], onDelete: Restrict)

  @@index([formulaId])
  @@map("product_formula_lines")
}

model StockMovement {
  id        String       @id @default(uuid()) @db.Uuid
  reference String // Internal movement reference
  productId String       @map("product_id") @db.Uuid
  type      MovementType
  quantity  Decimal      @db.Decimal(12, 3)
  unit      String
  unitCost  Decimal      @map("unit_cost") @db.Decimal(12, 2)
  totalCost Decimal      @map("total_cost") @db.Decimal(12, 2)

  warehouseFromId String? @map("warehouse_from_id") @db.Uuid
  warehouseToId   String? @map("warehouse_to_id") @db.Uuid

  sourceLocation      String?  @map("source_location")
  destinationLocation String?  @map("destination_location")
  reason              String?
  date                DateTime @default(now())

  createdBy String?  @map("created_by") @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User?      @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  warehouseFrom Warehouse? @relation("WarehouseFrom", fields: [warehouseFromId], references: [id])
  warehouseTo   Warehouse? @relation("WarehouseTo", fields: [warehouseToId], references: [id])

  @@index([companyId])
  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

model Sale {
  id            String        @id @default(uuid()) @db.Uuid
  invoiceNumber String        @map("invoice_number")
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  status        SaleStatus    @default(DRAFT)
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  companyId     String        @map("company_id") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at")

  company Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items   SaleItem[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@map("sales")
}

model SaleItem {
  id                String  @id @default(uuid()) @db.Uuid
  saleId            String  @map("sale_id") @db.Uuid
  productId         String  @map("product_id") @db.Uuid
  quantity          Int
  unitPriceSnapshot Decimal @map("unit_price_snapshot") @db.Decimal(10, 2)
  unitCostSnapshot  Decimal @map("unit_cost_snapshot") @db.Decimal(10, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Expense {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  amount    Decimal  @db.Decimal(12, 2)
  category  String
  companyId String   @map("company_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("expenses")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String
  entity    String
  entityId  String   @map("entity_id")
  userId    String?  @map("user_id") @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model ManufacturingOrder {
  id                 String                   @id @default(uuid()) @db.Uuid
  companyId          String                   @map("company_id") @db.Uuid
  reference          String
  productId          String                   @map("product_id") @db.Uuid
  formulaId          String                   @map("formula_id") @db.Uuid
  status             ManufacturingOrderStatus @default(DRAFT)
  plannedQuantity    Decimal                  @map("planned_quantity") @db.Decimal(12, 3)
  producedQuantity   Decimal                  @default(0) @map("produced_quantity") @db.Decimal(12, 3)
  unit               String
  plannedDate        DateTime                 @map("planned_date")
  startedAt          DateTime?                @map("started_at")
  completedAt        DateTime?                @map("completed_at")
  notes              String?
  totalEstimatedCost Decimal                  @default(0) @map("total_estimated_cost") @db.Decimal(12, 2)
  totalActualCost    Decimal?                 @map("total_actual_cost") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product                  @relation(fields: [productId], references: [id], onDelete: Restrict)
  formula ProductFormula           @relation(fields: [formulaId], references: [id], onDelete: Restrict)
  lines   ManufacturingOrderLine[]

  @@unique([companyId, reference])
  @@index([companyId])
  @@index([productId])
  @@index([formulaId])
  @@map("manufacturing_orders")
}

model ManufacturingOrderLine {
  id                   String  @id @default(uuid()) @db.Uuid
  manufacturingOrderId String  @map("manufacturing_order_id") @db.Uuid
  componentProductId   String  @map("component_product_id") @db.Uuid
  formulaLineId        String? @map("formula_line_id") @db.Uuid
  requiredQuantity     Decimal @map("required_quantity") @db.Decimal(12, 3)
  consumedQuantity     Decimal @default(0) @map("consumed_quantity") @db.Decimal(12, 3)
  unit                 String
  wastagePercent       Decimal @default(0) @map("wastage_percent") @db.Decimal(5, 2)
  estimatedUnitCost    Decimal @default(0) @map("estimated_unit_cost") @db.Decimal(10, 2)
  estimatedLineCost    Decimal @default(0) @map("estimated_line_cost") @db.Decimal(12, 2)
  note                 String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  manufacturingOrder ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
  component          Product            @relation(fields: [componentProductId], references: [id], onDelete: Restrict)

  @@index([manufacturingOrderId])
  @@index([componentProductId])
  @@map("manufacturing_order_lines")
}
