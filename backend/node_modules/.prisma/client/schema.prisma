generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                         String                      @id @default(uuid()) @db.Uuid
  name                       String
  slug                       String                      @unique
  createdAt                  DateTime                    @default(now()) @map("created_at")
  address                    String?
  ai                         String?
  allowNegativeStock         Boolean                     @default(false) @map("allow_negative_stock")
  email                      String?
  logoUrl                    String?                     @map("logo_url")
  nif                        String?
  phone                      String?
  rc                         String?
  rib                        String?
  website                    String?
  auditLogs                  AuditLog[]
  customers                  Customer[]
  expenses                   Expense[]
  invoices                   Invoice[]
  licenseKeys                LicenseKey[]
  manufacturingOrders        ManufacturingOrder[]
  payments                   Payment[]
  productFamilies            ProductFamily[]
  billOfMaterials            BillOfMaterials[]
  productStocks              ProductStock[]
  products                   Product[]
  purchaseOrders             PurchaseOrder[]
  salesOrders                SalesOrder[]
  stockMovements             StockMovement[]
  stockReceptions            StockReception[]
  suppliers                  Supplier[]
  users                      User[]
  warehouses                 Warehouse[]
  collectionActivities       CollectionActivity[]
  abcClassifications         AbcClassification[]
  stockTurnoverAnalytics     StockTurnoverAnalytics[]
  deadStockItems             DeadStockItem[]
  reorderPoints              ReorderPoint[]
  supplierPerformanceMetrics SupplierPerformanceMetric[]
  stockMovementPatterns      StockMovementPattern[]

  @@map("companies")
}

model AbcClassification {
  id             String @id @default(uuid()) @db.Uuid
  productId      String @map("product_id") @db.Uuid
  companyId      String @map("company_id") @db.Uuid
  classification String @db.Char(1) // A, B, C

  annualRevenue               Decimal @map("annual_revenue") @db.Decimal(15, 2)
  annualUnitsSold             Int     @map("annual_units_sold")
  revenuePercentage           Decimal @map("revenue_percentage") @db.Decimal(5, 2)
  cumulativeRevenuePercentage Decimal @map("cumulative_revenue_percentage") @db.Decimal(5, 2)

  averageStockValue Decimal @map("average_stock_value") @db.Decimal(15, 2)
  stockTurnoverRate Decimal @map("stock_turnover_rate") @db.Decimal(8, 2)
  daysInStock       Decimal @map("days_in_stock") @db.Decimal(8, 2)

  classifiedAt DateTime @default(now()) @map("classified_at")
  periodStart  DateTime @map("period_start")
  periodEnd    DateTime @map("period_end")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([classification])
  @@index([companyId])
  @@index([annualRevenue(sort: Desc)])
  @@map("abc_classifications")
}

model StockTurnoverAnalytics {
  id          String  @id @default(uuid()) @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  warehouseId String? @map("warehouse_id") @db.Uuid
  companyId   String  @map("company_id") @db.Uuid

  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")

  beginningInventory Decimal @map("beginning_inventory") @db.Decimal(12, 3)
  endingInventory    Decimal @map("ending_inventory") @db.Decimal(12, 3)
  averageInventory   Decimal @map("average_inventory") @db.Decimal(12, 3)
  unitsSold          Decimal @map("units_sold") @db.Decimal(12, 3)
  turnoverRatio      Decimal @map("turnover_ratio") @db.Decimal(8, 2)
  daysToSell         Decimal @map("days_to_sell") @db.Decimal(8, 2)

  costOfGoodsSold       Decimal @map("cost_of_goods_sold") @db.Decimal(15, 2)
  averageInventoryValue Decimal @map("average_inventory_value") @db.Decimal(15, 2)

  createdAt DateTime @default(now()) @map("created_at")

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId, periodStart, periodEnd, companyId])
  @@index([productId])
  @@index([companyId])
  @@index([daysToSell])
  @@map("stock_turnover_analytics")
}

model DeadStockItem {
  id          String  @id @default(uuid()) @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  warehouseId String? @map("warehouse_id") @db.Uuid
  companyId   String  @map("company_id") @db.Uuid

  quantity   Decimal @db.Decimal(12, 3)
  stockValue Decimal @map("stock_value") @db.Decimal(15, 2)

  lastSaleDate      DateTime? @map("last_sale_date")
  daysWithoutSale   Int       @map("days_without_sale")
  lastPurchaseDate  DateTime? @map("last_purchase_date")
  daysSincePurchase Int       @map("days_since_purchase")

  category String  @map("dead_stock_category") // slow_moving, obsolete, damaged, expired
  reason   String?

  actionRecommended String?   @map("action_recommended") // discount, return_to_supplier, dispose, transfer
  actionTaken       String?   @map("action_taken")
  actionDate        DateTime? @map("action_date")
  actionBy          String?   @map("action_by") @db.Uuid

  identifiedAt DateTime @default(now()) @map("identified_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([category])
  @@index([companyId])
  @@map("dead_stock_items")
}

model ReorderPoint {
  id          String  @id @default(uuid()) @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  warehouseId String? @map("warehouse_id") @db.Uuid
  companyId   String  @map("company_id") @db.Uuid

  reorderPoint    Decimal  @map("reorder_point") @db.Decimal(12, 3)
  safetyStock     Decimal  @map("safety_stock") @db.Decimal(12, 3)
  reorderQuantity Decimal  @map("reorder_quantity") @db.Decimal(12, 3)
  maximumStock    Decimal? @map("maximum_stock") @db.Decimal(12, 3)

  leadTimeDays       Int?     @map("lead_time_days")
  averageDailyDemand Decimal? @map("average_daily_demand") @db.Decimal(12, 3)
  demandVariability  Decimal? @map("demand_variability") @db.Decimal(12, 3)
  serviceLevel       Decimal  @default(95.00) @map("service_level") @db.Decimal(5, 2)

  autoCalculate     Boolean   @default(true) @map("auto_calculate")
  calculationMethod String?   @map("calculation_method") // fixed, dynamic, seasonal
  lastCalculatedAt  DateTime? @map("last_calculated_at")

  alertEnabled   Boolean  @default(true) @map("alert_enabled")
  alertThreshold Decimal? @map("alert_threshold") @db.Decimal(12, 3)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId, companyId])
  @@index([productId])
  @@index([companyId])
  @@map("reorder_points")
}

model SupplierPerformanceMetric {
  id         String @id @default(uuid()) @db.Uuid
  supplierId String @map("supplier_id") @db.Uuid
  companyId  String @map("company_id") @db.Uuid

  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")

  totalOrders        Int      @default(0) @map("total_orders")
  onTimeDeliveries   Int      @default(0) @map("on_time_deliveries")
  lateDeliveries     Int      @default(0) @map("late_deliveries")
  averageDelayDays   Decimal? @map("average_delay_days") @db.Decimal(8, 2)
  onTimeDeliveryRate Decimal? @map("on_time_delivery_rate") @db.Decimal(5, 2)

  totalItemsReceived    Decimal? @map("total_items_received") @db.Decimal(12, 3)
  defectiveItems        Decimal? @map("defective_items") @db.Decimal(12, 3)
  returnedItems         Decimal? @map("returned_items") @db.Decimal(12, 3)
  qualityAcceptanceRate Decimal? @map("quality_acceptance_rate") @db.Decimal(5, 2)

  totalPurchaseValue         Decimal? @map("total_purchase_value") @db.Decimal(15, 2)
  averageOrderValue          Decimal? @map("average_order_value") @db.Decimal(15, 2)
  paymentTermsComplianceRate Decimal? @map("payment_terms_compliance_rate") @db.Decimal(5, 2)

  priceCompetitivenessScore Decimal? @map("price_competitiveness_score") @db.Decimal(5, 2)
  discountRate              Decimal? @map("discount_rate") @db.Decimal(5, 2)

  overallPerformanceScore Decimal? @map("overall_performance_score") @db.Decimal(5, 2)
  performanceGrade        String?  @map("performance_grade") @db.Char(1) // A, B, C, D, F

  recommendedStatus String? @map("recommended_status") // preferred, approved, watch_list, blocked
  notes             String?

  calculatedAt DateTime @default(now()) @map("calculated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([supplierId, periodStart, periodEnd, companyId])
  @@index([supplierId])
  @@index([companyId])
  @@map("supplier_performance_metrics")
}

model StockMovementPattern {
  id        String @id @default(uuid()) @db.Uuid
  productId String @map("product_id") @db.Uuid
  companyId String @map("company_id") @db.Uuid

  patternType         String? @map("pattern_type") // seasonal, trending_up, trending_down, stable, erratic
  seasonalityDetected Boolean @default(false) @map("seasonality_detected")
  peakMonths          Int[]   @map("peak_months")
  lowMonths           Int[]   @map("low_months")

  trendDirection  String?  @map("trend_direction") // increasing, decreasing, stable
  trendPercentage Decimal? @map("trend_percentage") @db.Decimal(8, 2)

  predictedDemandNext30Days Decimal? @map("predicted_demand_next_30_days") @db.Decimal(12, 3)
  predictedDemandNext90Days Decimal? @map("predicted_demand_next_90_days") @db.Decimal(12, 3)
  forecastConfidence        Decimal? @map("forecast_confidence") @db.Decimal(5, 2)

  analysisPeriodStart DateTime? @map("analysis_period_start")
  analysisPeriodEnd   DateTime? @map("analysis_period_end")
  dataPointsAnalyzed  Int?      @map("data_points_analyzed")

  analyzedAt DateTime @default(now()) @map("analyzed_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([companyId])
  @@map("stock_movement_patterns")
}

model User {
  id             String          @id @default(uuid()) @db.Uuid
  email          String          @unique
  passwordHash   String?         @map("password_hash")
  role           Role            @default(EMPLOYEE)
  status         UserStatus      @default(ACTIVE)
  companyId      String          @map("company_id") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at")
  auditLogs      AuditLog[]
  stockMovements StockMovement[]
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // RBAC Relations
  roles         UserRole[]
  auditExecuted PermissionAuditLog[] @relation("AuditExecutor")
  auditTargeted PermissionAuditLog[] @relation("AuditTarget")

  @@index([companyId])
  @@map("users")
}

model AppRole {
  id           String               @id @default(uuid()) @db.Uuid
  name         String               @unique
  displayName  String               @map("display_name")
  description  String?
  isSystemRole Boolean              @default(false) @map("is_system_role")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  permissions  RolePermission[]
  users        UserRole[]
  policies     DataAccessPolicy[]
  auditLogs    PermissionAuditLog[]

  @@map("app_roles")
}

model AppPermission {
  id          String               @id @default(uuid()) @db.Uuid
  module      String
  resource    String
  action      String
  description String?
  createdAt   DateTime             @default(now()) @map("created_at")
  roles       RolePermission[]
  auditLogs   PermissionAuditLog[]

  @@unique([module, resource, action])
  @@map("app_permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  grantedAt    DateTime @default(now()) @map("granted_at")
  grantedBy    String?  @map("granted_by") @db.Uuid

  role       AppRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission AppPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  roleId     String    @map("role_id") @db.Uuid
  assignedAt DateTime  @default(now()) @map("assigned_at")
  assignedBy String?   @map("assigned_by") @db.Uuid
  expiresAt  DateTime? @map("expires_at")
  isActive   Boolean   @default(true) @map("is_active")

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role AppRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model PermissionAuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  actionType   String   @map("action_type") // role_assigned, role_revoked, etc.
  roleId       String?  @map("role_id") @db.Uuid
  permissionId String?  @map("permission_id") @db.Uuid
  targetUserId String?  @map("target_user_id") @db.Uuid
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  details      Json?
  createdAt    DateTime @default(now()) @map("created_at")

  executor   User?          @relation("AuditExecutor", fields: [userId], references: [id])
  target     User?          @relation("AuditTarget", fields: [targetUserId], references: [id])
  role       AppRole?       @relation(fields: [roleId], references: [id])
  permission AppPermission? @relation(fields: [permissionId], references: [id])

  @@map("permission_audit_logs")
}

model DataAccessPolicy {
  id              String   @id @default(uuid()) @db.Uuid
  roleId          String   @map("role_id") @db.Uuid
  tableName       String   @map("table_name")
  policyType      String   @map("policy_type") // own_data, department_data, all_data, custom
  filterCondition Json?    @map("filter_condition")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  role AppRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("data_access_policies")
}

model LicenseKey {
  id        String        @id @default(uuid()) @db.Uuid
  key       String        @unique
  status    LicenseStatus @default(ACTIVE)
  expiresAt DateTime      @map("expires_at")
  companyId String?       @map("company_id") @db.Uuid
  company   Company?      @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("license_keys")
}

model Product {
  id                      String                   @id @default(uuid()) @db.Uuid
  name                    String
  sku                     String
  companyId               String                   @map("company_id") @db.Uuid
  createdAt               DateTime                 @default(now()) @map("created_at")
  familyId                String?                  @map("family_id") @db.Uuid
  taxRate                 Decimal                  @default(0.20) @map("tax_rate") @db.Decimal(5, 2)
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  articleType             ArticleType              @default(FINISHED_PRODUCT) @map("article_type")
  description             String?
  isActive                Boolean                  @default(true) @map("is_active")
  minStock                Decimal                  @default(0) @map("min_stock") @db.Decimal(12, 3)
  purchasePriceHt         Decimal?                 @map("purchase_price_ht") @db.Decimal(10, 2)
  secondaryName           String?                  @map("secondary_name")
  unit                    String                   @default("pcs")
  barcode                 String?                  @map("barcode")
  internalReference       String?                  @map("internal_reference")
  isBlocked               Boolean                  @default(false) @map("is_blocked")
  maxStock                Decimal?                 @map("max_stock") @db.Decimal(12, 3)
  salePriceHt             Decimal?                 @map("sale_price_ht") @db.Decimal(10, 2)
  standardCost            Decimal                  @map("standard_cost") @db.Decimal(10, 2)
  stockQuantity           Decimal                  @default(0) @map("stock_quantity") @db.Decimal(12, 3)
  preferredSupplierId     String?                  @map("preferred_supplier_id") @db.Uuid
  stockValue              Decimal                  @default(0) @map("stock_value") @db.Decimal(12, 2)
  trackStock              Boolean                  @default(true) @map("track_stock")
  manufacturingOrderLines ManufacturingOrderLine[]
  manufacturingOrders     ManufacturingOrder[]
  bomsAsFinishedProduct   BillOfMaterials[]        @relation("FinishedProduct")
  bomComponentsAsRaw      BOMComponent[]           @relation("RawMaterial")
  stocks                  ProductStock[]
  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  family                  ProductFamily?           @relation(fields: [familyId], references: [id])
  preferredSupplier       Supplier?                @relation("PreferredSupplier", fields: [preferredSupplierId], references: [id])
  purchaseOrderLines      PurchaseOrderLine[]
  salesOrderLines         SalesOrderLine[]
  stockMovements          StockMovement[]
  stockReceptionLines     StockReceptionLine[]
  abcClassifications      AbcClassification[]
  stockTurnoverAnalytics  StockTurnoverAnalytics[]
  deadStockItems          DeadStockItem[]
  reorderPoints           ReorderPoint[]
  stockMovementPatterns   StockMovementPattern[]

  @@unique([companyId, sku])
  @@index([companyId])
  @@index([id, isActive])
  @@index([sku])
  @@map("products")
}

model Warehouse {
  id                     String                   @id @default(uuid()) @db.Uuid
  companyId              String                   @map("company_id") @db.Uuid
  name                   String
  code                   String?
  location               String?
  isActive               Boolean                  @default(true) @map("is_active")
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @updatedAt @map("updated_at")
  stocks                 ProductStock[]
  movementsFrom          StockMovement[]          @relation("WarehouseFrom")
  movementsTo            StockMovement[]          @relation("WarehouseTo")
  stockReceptions        StockReception[]
  stockTurnoverAnalytics StockTurnoverAnalytics[]
  deadStockItems         DeadStockItem[]
  reorderPoints          ReorderPoint[]
  manufacturingOrders    ManufacturingOrder[]
  company                Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("warehouses")
}

model ProductStock {
  id               String    @id @default(uuid()) @db.Uuid
  productId        String    @map("product_id") @db.Uuid
  warehouseId      String    @map("warehouse_id") @db.Uuid
  quantity         Decimal   @default(0) @db.Decimal(12, 3)
  reservedQuantity Decimal   @default(0) @map("reserved_quantity") @db.Decimal(12, 3)
  minThreshold     Decimal   @default(0) @map("min_threshold") @db.Decimal(12, 3)
  maxThreshold     Decimal?  @map("max_threshold") @db.Decimal(12, 3)
  updatedAt        DateTime  @updatedAt @map("updated_at")
  companyId        String    @map("company_id") @db.Uuid
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse        Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId, companyId])
  @@index([productId])
  @@index([companyId])
  @@map("product_stocks")
}

model ProductFamily {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  description String?
  companyId   String          @map("company_id") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  code        String?
  colorBadge  String?         @map("color_badge")
  parentId    String?         @map("parent_id") @db.Uuid
  sortOrder   Int             @default(0) @map("sort_order")
  isActive    Boolean         @default(true) @map("is_active")
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent      ProductFamily?  @relation("FamilyHierarchy", fields: [parentId], references: [id])
  children    ProductFamily[] @relation("FamilyHierarchy")
  products    Product[]

  @@index([companyId])
  @@map("product_families")
}

model BillOfMaterials {
  id                 String               @id @default(uuid()) @db.Uuid
  companyId          String               @map("company_id") @db.Uuid
  productId          String               @map("product_id") @db.Uuid
  name               String
  version            String               @default("1.0")
  isActive           Boolean              @default(true) @map("is_active")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  code               String?
  description        String?
  outputQuantity     Decimal              @default(1.0) @map("output_quantity") @db.Decimal(12, 3)
  outputUnit         String               @map("output_unit")
  scrapPercent       Decimal              @default(0) @map("scrap_percent") @db.Decimal(5, 2)
  status             FormulaStatus        @default(DRAFT)
  manufacturingOrder ManufacturingOrder[]
  components         BOMComponent[]
  company            Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product            Product              @relation("FinishedProduct", fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
  @@map("bill_of_materials")
}

model BOMComponent {
  id                 String          @id @default(uuid()) @db.Uuid
  bomId              String          @map("bom_id") @db.Uuid
  componentProductId String          @map("component_product_id") @db.Uuid
  quantity           Decimal         @db.Decimal(12, 3)
  unit               String
  wastagePercent     Decimal         @default(0) @map("wastage_percent") @db.Decimal(5, 2)
  sortOrder          Int             @default(0) @map("sort_order")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  note               String?
  component          Product         @relation("RawMaterial", fields: [componentProductId], references: [id], onDelete: Restrict)
  bom                BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)

  @@index([bomId])
  @@map("bom_components")
}

model StockMovement {
  id           String       @id @default(uuid()) @db.Uuid
  companyId    String       @map("company_id") @db.Uuid
  productId    String       @map("product_id") @db.Uuid
  quantity     Decimal      @db.Decimal(12, 3)
  movementType String       @default("IN") @map("movement_type") // IN, OUT, ADJUSTMENT
  type         MovementType @default(IN)
  reference    String
  reason       String?
  date         DateTime     @default(now())
  unitCost     Decimal      @default(0) @map("unit_cost") @db.Decimal(12, 2)
  totalCost    Decimal      @default(0) @map("total_cost") @db.Decimal(12, 2)
  unit         String       @default("pcs")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.Uuid

  warehouseFromId String? @map("warehouse_from_id") @db.Uuid
  warehouseToId   String? @map("warehouse_to_id") @db.Uuid
  salesOrderId    String? @map("sales_order_id") @db.Uuid

  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [createdBy], references: [id])
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  salesOrder    SalesOrder? @relation(fields: [salesOrderId], references: [id])
  warehouseFrom Warehouse?  @relation("WarehouseFrom", fields: [warehouseFromId], references: [id])
  warehouseTo   Warehouse?  @relation("WarehouseTo", fields: [warehouseToId], references: [id])

  @@index([companyId])
  @@index([productId])
  @@index([productId, warehouseToId, type])
  @@index([date])
  @@index([createdAt])
  @@map("stock_movements")
}

model Customer {
  id                   String               @id @default(uuid()) @db.Uuid
  companyId            String               @map("company_id") @db.Uuid
  name                 String
  contact              String?
  taxId                String?              @map("tax_id")
  email                String?
  phone                String?
  address              String?
  creditLimit          Decimal              @default(0) @map("credit_limit") @db.Decimal(12, 2)
  isActive             Boolean              @default(true) @map("is_active")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  // Intelligence Fields
  segment              CustomerSegment?     @map("segment")
  customerType         CustomerType?        @map("customer_type")
  paymentBehavior      PaymentBehavior?     @map("payment_behavior")
  riskLevel            RiskLevel?           @map("risk_level")
  totalRevenue         Decimal              @default(0) @map("total_revenue") @db.Decimal(14, 2)
  avgPaymentDelay      Int                  @default(0) @map("avg_payment_delay")
  company              Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices             Invoice[]
  salesOrders          SalesOrder[]
  collectionActivities CollectionActivity[]

  @@index([companyId])
  @@index([segment])
  @@index([customerType])
  @@map("customers")
}

model SalesOrder {
  id             String           @id @default(uuid()) @db.Uuid
  companyId      String           @map("company_id") @db.Uuid
  customerId     String           @map("customer_id") @db.Uuid
  reference      String
  status         SalesOrderStatus @default(DRAFT)
  date           DateTime         @default(now())
  totalAmountHt  Decimal          @map("total_amount_ht") @db.Decimal(12, 2)
  totalAmountTva Decimal          @map("total_amount_tva") @db.Decimal(12, 2)
  totalAmountTtc Decimal          @map("total_amount_ttc") @db.Decimal(12, 2)
  notes          String?
  completedAt    DateTime?        @map("completed_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  invoice        Invoice?
  lines          SalesOrderLine[]
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer       Customer         @relation(fields: [customerId], references: [id])
  stockMovements StockMovement[]

  @@unique([companyId, reference])
  @@index([companyId])
  @@index([customerId])
  @@index([status])
  @@index([date])
  @@index([date, status])
  @@map("sales_orders")
}

model SalesOrderLine {
  id               String     @id @default(uuid()) @db.Uuid
  salesOrderId     String     @map("sales_order_id") @db.Uuid
  productId        String     @map("product_id") @db.Uuid
  quantity         Decimal    @db.Decimal(12, 3)
  shippedQuantity  Decimal    @default(0) @map("shipped_quantity") @db.Decimal(12, 3)
  unit             String
  unitPriceHt      Decimal    @map("unit_price_ht") @db.Decimal(12, 2)
  unitCostSnapshot Decimal    @map("unit_cost_snapshot") @db.Decimal(12, 2)
  taxRate          Decimal    @default(0.19) @map("tax_rate") @db.Decimal(5, 2)
  lineTotalHt      Decimal    @map("line_total_ht") @db.Decimal(12, 2)
  lineTotalTtc     Decimal    @map("line_total_ttc") @db.Decimal(12, 2)
  product          Product    @relation(fields: [productId], references: [id])
  salesOrder       SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@index([salesOrderId])
  @@index([productId])
  @@map("sales_order_lines")
}

model Invoice {
  id                   String               @id @default(uuid()) @db.Uuid
  companyId            String               @map("company_id") @db.Uuid
  salesOrderId         String?              @unique @map("sales_order_id") @db.Uuid
  customerId           String               @map("customer_id") @db.Uuid
  reference            String
  status               InvoiceStatus        @default(DRAFT)
  date                 DateTime             @default(now())
  dueDate              DateTime?            @map("due_date")
  lastReminderSent     DateTime?            @map("last_reminder_sent")
  reminderCount        Int                  @default(0) @map("reminder_count")
  totalAmountHt        Decimal              @map("total_amount_ht") @db.Decimal(12, 2)
  totalAmountTva       Decimal              @map("total_amount_tva") @db.Decimal(12, 2)
  totalAmountStamp     Decimal              @default(0) @map("total_amount_stamp") @db.Decimal(12, 2)
  totalAmountTtc       Decimal              @map("total_amount_ttc") @db.Decimal(12, 2)
  amountPaid           Decimal              @default(0) @map("amount_paid") @db.Decimal(12, 2)
  amountRemaining      Decimal              @map("amount_remaining") @db.Decimal(12, 2)
  paymentMethod        PaymentMethod        @default(CASH) @map("payment_method")
  notes                String?
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  company              Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer             Customer             @relation(fields: [customerId], references: [id])
  salesOrder           SalesOrder?          @relation(fields: [salesOrderId], references: [id])
  payments             Payment[]
  collectionActivities CollectionActivity[]

  @@unique([companyId, reference])
  @@index([companyId])
  @@index([customerId])
  @@index([status])
  @@index([date])
  @@index([dueDate, status])
  @@map("invoices")
}

model Payment {
  id        String        @id @default(uuid()) @db.Uuid
  companyId String        @map("company_id") @db.Uuid
  invoiceId String        @map("invoice_id") @db.Uuid
  date      DateTime      @default(now())
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod @default(CASH)
  reference String?
  notes     String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([invoiceId])
  @@map("payments")
}

model Expense {
  id            String        @id @default(uuid()) @db.Uuid
  title         String
  amount        Decimal       @db.Decimal(12, 2)
  category      String
  companyId     String        @map("company_id") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at")
  date          DateTime      @default(now())
  notes         String?
  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  reference     String?
  supplierId    String?       @map("supplier_id") @db.Uuid
  updatedAt     DateTime      @updatedAt @map("updated_at")
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])

  @@index([companyId])
  @@index([supplierId])
  @@map("expenses")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  action      String // CREATE, UPDATE, DELETE
  entity      String // Product, Invoice, etc.
  entityId    String   @map("entity_id")
  userId      String?  @map("user_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  metadata    Json? // IP, UserAgent, etc.
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ManufacturingOrder {
  id                 String                   @id @default(uuid()) @db.Uuid
  companyId          String                   @map("company_id") @db.Uuid
  reference          String
  productId          String                   @map("product_id") @db.Uuid
  formulaId          String                   @map("formula_id") @db.Uuid
  warehouseId        String?                  @map("warehouse_id") @db.Uuid
  status             ManufacturingOrderStatus @default(DRAFT)
  plannedQuantity    Decimal                  @map("planned_quantity") @db.Decimal(12, 3)
  producedQuantity   Decimal                  @default(0) @map("produced_quantity") @db.Decimal(12, 3)
  unit               String
  plannedDate        DateTime                 @map("planned_date")
  startedAt          DateTime?                @map("started_at")
  completedAt        DateTime?                @map("completed_at")
  notes              String?
  totalEstimatedCost Decimal                  @default(0) @map("total_estimated_cost") @db.Decimal(12, 2)
  totalActualCost    Decimal?                 @map("total_actual_cost") @db.Decimal(12, 2)
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  lines              ManufacturingOrderLine[]
  company            Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  formula            BillOfMaterials          @relation(fields: [formulaId], references: [id])
  product            Product                  @relation(fields: [productId], references: [id])
  warehouse          Warehouse?               @relation(fields: [warehouseId], references: [id])

  @@unique([companyId, reference])
  @@index([companyId])
  @@index([productId])
  @@index([formulaId])
  @@index([warehouseId])
  @@map("manufacturing_orders")
}

model ManufacturingOrderLine {
  id                   String             @id @default(uuid()) @db.Uuid
  manufacturingOrderId String             @map("manufacturing_order_id") @db.Uuid
  componentProductId   String             @map("component_product_id") @db.Uuid
  bomComponentId       String?            @map("bom_component_id") @db.Uuid
  requiredQuantity     Decimal            @map("required_quantity") @db.Decimal(12, 3)
  consumedQuantity     Decimal            @default(0) @map("consumed_quantity") @db.Decimal(12, 3)
  unit                 String
  wastagePercent       Decimal            @default(0) @map("wastage_percent") @db.Decimal(5, 2)
  estimatedUnitCost    Decimal            @default(0) @map("estimated_unit_cost") @db.Decimal(10, 2)
  estimatedLineCost    Decimal            @default(0) @map("estimated_line_cost") @db.Decimal(12, 2)
  note                 String?
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  component            Product            @relation(fields: [componentProductId], references: [id])
  manufacturingOrder   ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)

  @@index([manufacturingOrderId])
  @@index([componentProductId])
