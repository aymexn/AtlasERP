  organizerId       String?           @map("organizer_id") @db.Uuid
  attendees         Json?             // [{"user_id": "uuid", "status": "accepted", "name": "..."}]
  reminderMinutes   Int[]             @map("reminder_minutes")
  status            String            @default("scheduled") // scheduled, cancelled, completed
  color             String?           @default("#3b82f6")
  createdBy         String?           @map("created_by") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  organizer         User?             @relation("EventOrganizer", fields: [organizerId], references: [id])

  @@index([companyId])
  @@index([startDatetime, endDatetime])
  @@map("calendar_events")
}

model CollaborationDocument {
  id                String            @id @default(uuid()) @db.Uuid
  companyId         String            @map("company_id") @db.Uuid
  name              String
  description       String?
  fileUrl           String            @map("file_url")
  fileType          String?           @map("file_type")
  fileSize          BigInt?           @map("file_size")
  folderPath        String?           @map("folder_path")
  tags              String[]
  version           String            @default("1.0")
  isLatestVersion   Boolean           @default(true) @map("is_latest_version")
  parentDocumentId  String?           @map("parent_document_id") @db.Uuid
  visibility        String            @default("private")
  departmentId      String?           @map("department_id") @db.Uuid
  projectId         String?           @map("project_id") @db.Uuid
  allowedUserIds    String[]          @map("allowed_users") @db.Uuid
  status            String            @default("draft") // draft, pending_approval, approved, archived
  requiresApproval  Boolean           @default(false) @map("requires_approval")
  workflowId        String?           @map("workflow_id") @db.Uuid
  uploadedBy        String?           @map("uploaded_by") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project           Project?          @relation(fields: [projectId], references: [id])
  uploader          User?             @relation(fields: [uploadedBy], references: [id])
  parentDocument    CollaborationDocument? @relation("DocumentVersions", fields: [parentDocumentId], references: [id])
  versions          CollaborationDocument[] @relation("DocumentVersions")
  approvalWorkflow  ApprovalWorkflow? @relation(fields: [workflowId], references: [id])

  @@index([companyId])
  @@index([folderPath])
  @@index([projectId])
  @@map("collaboration_documents")
}

model ApprovalWorkflow {
  id                String            @id @default(uuid()) @db.Uuid
  companyId         String            @map("company_id") @db.Uuid
  workflowName      String            @map("workflow_name")
  workflowType      String?           @map("workflow_type")
  approvalSteps     Json              @map("approval_steps")
  isActive          Boolean           @default(true) @map("is_active")
  autoApproveLimit  Decimal?          @map("auto_approve_threshold") @db.Decimal(15, 2)
  createdBy         String?           @map("created_by") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documents         CollaborationDocument[]
  requests          ApprovalRequest[]

  @@map("approval_workflows")
}

model ApprovalRequest {
  id                String            @id @default(uuid()) @db.Uuid
  workflowId        String            @map("workflow_id") @db.Uuid
  requestType       String?           @map("request_type")
  resourceType      String?           @map("resource_type")
  resourceId        String?           @map("resource_id") @db.Uuid
  requesterId       String?           @map("requester_id") @db.Uuid
  requestDate       DateTime          @default(now()) @map("request_date")
  currentStep       Int               @default(1) @map("current_step")
  status            String            @default("pending")
  approvalHistory   Json?             @map("approval_history")
  finalDecision     String?           @map("final_decision")
  decidedAt         DateTime?         @map("decided_at")
  decidedBy         String?           @map("decided_by") @db.Uuid
  decisionNotes     String?           @map("decision_notes")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  workflow          ApprovalWorkflow  @relation(fields: [workflowId], references: [id])
  requester         User?             @relation("RequestRequester", fields: [requesterId], references: [id])
  decider           User?             @relation("RequestDecider", fields: [decidedBy], references: [id])

  @@index([status])
  @@map("approval_requests")
}

model Message {
  id                String            @id @default(uuid()) @db.Uuid
  senderId          String            @map("sender_id") @db.Uuid
  recipientId       String?           @map("recipient_id") @db.Uuid
  conversationId    String?           @map("conversation_id")
  isGroupMessage    Boolean           @default(false) @map("is_group_message")
  groupParticipants String[]          @map("group_participants") @db.Uuid
  messageText       String            @map("message_text")
  messageType       String            @default("text") @map("message_type")
  attachments       Json?
  isRead            Boolean           @default(false) @map("is_read")
  readAt            DateTime?         @map("read_at")
  replyToId         String?           @map("reply_to_message_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at")
  deletedAt         DateTime?         @map("deleted_at")

  sender            User              @relation("MessageSender", fields: [senderId], references: [id])
  recipient         User?             @relation("MessageRecipient", fields: [recipientId], references: [id])
  replyTo           Message?          @relation("MessageReplies", fields: [replyToId], references: [id])
  replies           Message[]         @relation("MessageReplies")

  @@index([conversationId])
  @@map("messages")
}

model ActivityFeed {
  id                String            @id @default(uuid()) @db.Uuid
  companyId         String            @map("company_id") @db.Uuid
  activityType      String            @map("activity_type")
  userId            String            @map("user_id") @db.Uuid
  userName          String?           @map("user_name")
  resourceType      String            @map("resource_type")
  resourceId        String            @map("resource_id") @db.Uuid
  resourceTitle     String?           @map("resource_title")
  description       String?           @map("activity_description")
  metadata          Json?
  visibility        String            @default("public")
  departmentId      String?           @map("department_id") @db.Uuid
  projectId         String?           @map("project_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id])
  project           Project?          @relation(fields: [projectId], references: [id])

  @@index([createdAt])
  @@map("activity_feed")
}

model Notification {
  id                String            @id @default(uuid()) @db.Uuid
  userId            String            @map("user_id") @db.Uuid
  notificationType  String            @map("notification_type")
  title             String
  message           String?
  linkUrl           String?           @map("link_url")
  actionType        String?           @map("action_type")
  resourceType      String?           @map("resource_type")
  resourceId        String?           @map("resource_id") @db.Uuid
  isRead            Boolean           @default(false) @map("is_read")
  readAt            DateTime?         @map("read_at")
  sentViaEmail      Boolean           @default(false) @map("sent_via_email")
  sentViaPush       Boolean           @default(false) @map("sent_via_push")
  createdAt         DateTime          @default(now()) @map("created_at")

  user              User              @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model UnitOfMeasure {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String
  symbol    String
  type      String   @default("reference") // reference, bigger, smaller
  isActive  Boolean  @default(true) @map("is_active")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productUoms ProductUom[]
  stockProducts Product[] @relation("StockUom")
  bomComponents BOMComponent[]
  stockMovements StockMovement[]
  salesOrderLines SalesOrderLine[]
  purchaseOrderLines PurchaseOrderLine[]
  stockReceptionLines StockReceptionLine[]
  moLines           ManufacturingOrderLine[]

  @@unique([companyId, symbol])
  @@map("unit_of_measures")
}

model ProductUom {
  id               String        @id @default(uuid()) @db.Uuid
  productId        String        @map("product_id") @db.Uuid
  uomId            String        @map("uom_id") @db.Uuid
  isDefault        Boolean       @default(false) @map("is_default")
  conversionFactor Decimal       @default(1) @map("conversion_factor") @db.Decimal(12, 5)
  purpose          String?       // purchase, sales, stock, production
  createdAt        DateTime      @default(now()) @map("created_at")
  product          Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  uom              UnitOfMeasure @relation(fields: [uomId], references: [id])

  @@unique([productId, uomId, purpose])
  @@map("product_uoms")
}

model ProductVariant {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  sku             String
  name            String?
  attributeValues Json?    @map("attribute_values")
  priceAdjustment Decimal  @default(0) @map("price_adjustment") @db.Decimal(12, 2)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  stocks          ProductStock[] @relation("VariantStocks")
  movements       StockMovement[] @relation("VariantMovements")
  bomLines        BOMComponent[] @relation("VariantBomLines")
  moLines         ManufacturingOrderLine[] @relation("VariantMoLines")
  outputBoms      BillOfMaterials[] @relation("VariantBomOutput")
  outputMos       ManufacturingOrder[] @relation("VariantMoOutput")
  purchaseLines   PurchaseOrderLine[] @relation("VariantPurchaseLines")
  receptionLines  StockReceptionLine[] @relation("VariantReceptionLines")

  @@unique([productId, sku])
  @@map("product_variants")
}

model SupplierProduct {
  id               String   @id @default(uuid()) @db.Uuid
  supplierId       String   @map("supplier_id") @db.Uuid
  productId        String   @map("product_id") @db.Uuid
  supplierSku      String?  @map("supplier_sku")
  costPrice        Decimal? @map("cost_price") @db.Decimal(12, 2)
  minOrderQuantity Decimal  @default(0) @map("min_order_quantity") @db.Decimal(12, 4)
  leadTimeDays     Int?     @map("lead_time_days")
  isPreferred      Boolean  @default(false) @map("is_preferred")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  supplier         Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
  @@map("supplier_products")
}
